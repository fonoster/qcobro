# PostgreSQL connection used by Prisma (mods/apiserver).
# Matches the local database service defined in compose.yaml.
DATABASE_URL="postgresql://qcobro:qcobro@localhost:5432/qcobro?schema=public"

# API server port (optional, defaults to 3000).
# PORT=3000

# --- Identity service (mods/identity-service) ---
# Separate PostgreSQL database for Fonoster Identity.
IDENTITY_DATABASE_URL="postgresql://qcobro:qcobro@identity-db:5432/identity?schema=public"
# Field-encryption key for Identity (prisma-field-encryption / cloak format).
# Generate: k1.aesgcm256.$(openssl rand -base64 32 | tr '+/' '-_' | tr -d '=')
IDENTITY_ENCRYPTION_KEY="k1.aesgcm256.REPLACE_ME"
# RS256 key pair used to sign/verify JWTs. Generate dev keys with:
#   openssl genpkey -algorithm RSA -pkeyopt rsa_keygen_bits:2048 -out keys/private.pem
#   openssl rsa -in keys/private.pem -pubout -out keys/public.pem
IDENTITY_PRIVATE_KEY_PATH="./keys/private.pem"
IDENTITY_PUBLIC_KEY_PATH="./keys/public.pem"
IDENTITY_PORT=50051
IDENTITY_ISSUER="qcobro"
# Where the apiserver reaches the Identity gRPC service.
IDENTITY_SERVICE_ENDPOINT="localhost:50051"

# --- Dev mail (Mailpit) for invite/verification emails ---
SMTP_HOST="localhost"
SMTP_PORT=1025
SMTP_SECURE=false
SMTP_SENDER="QCobro <no-reply@qcobro.local>"
# Mailpit web UI: http://localhost:8025
