{
  "database": {
    "url": "postgresql://qcobro:REPLACE_WITH_DB_PASSWORD@db.internal:5432/qcobro?schema=public"
  },
  "identity": {
    "databaseUrl": "postgresql://qcobro:REPLACE_WITH_DB_PASSWORD@identity-db.internal:5432/identity?schema=public",
    "encryptionKey": "k1.aesgcm256.REPLACE_WITH_GENERATED_CLOAK_KEY",
    "privateKeyPath": "/etc/qcobro/keys/private.pem",
    "publicKeyPath": "/etc/qcobro/keys/public.pem",
    "issuer": "https://app.qcobro.com",
    "audience": "qcobro",
    "accessTokenExpiresIn": "15m",
    "refreshTokenExpiresIn": "30d",
    "idTokenExpiresIn": "15m",
    "port": 50051,
    "endpoint": "identity:50051",
    "contactVerificationRequired": true,
    "twoFactorAuthenticationRequired": false,
    "workspaceInviteUrl": "https://app.qcobro.com/accept-invite",
    "workspaceInviteFailUrl": "https://app.qcobro.com/invite-failed",
    "workspaceInviteExpiration": "2d",
    "smtp": {
      "host": "smtp.your-provider.com",
      "port": 587,
      "secure": true,
      "sender": "QCobro <no-reply@qcobro.com>",
      "auth": {
        "user": "apikey",
        "pass": "REPLACE_WITH_SMTP_PASSWORD"
      }
    }
  },
  "apiserver": {
    "port": 3000
  }
}
