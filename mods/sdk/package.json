{
  "name": "@qcobro/sdk",
  "version": "1.3.0",
  "description": "Developer-friendly TypeScript SDK for the QCobro API.",
  "type": "module",
  "exports": {
    ".": "./dist/index.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
