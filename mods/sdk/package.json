    "@types/express": "^5.0.0",
    "express": "^5.0.0",
    "tsx": "^4.0.0",
    "typedoc": "^0.28.0",
    "typedoc-plugin-markdown": "^4.0.0",
    "typescript": "^5.9.0"
  }
