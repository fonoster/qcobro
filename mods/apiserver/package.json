{
  "name": "@qcobro/apiserver",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./src/trpc/index.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "node scripts/prisma.mjs generate && tsc -b --force",
    "clean": "rm -rf dist *.tsbuildinfo",
    "start": "node dist/index.js",
    "start:dev": "tsx watch src/index.ts",
    "test": "node --import tsx --test \"src/**/*.test.ts\"",
    "typecheck": "tsc --noEmit",
    "db:generate": "node scripts/prisma.mjs generate",
    "db:migrate": "node scripts/prisma.mjs migrate dev",
    "db:migrate:deploy": "node scripts/prisma.mjs migrate deploy",
    "db:studio": "node scripts/prisma.mjs studio",
    "db:seed": "tsx scripts/seed.ts"
  },
  "dependencies": {
    "@fonoster/identity-client": "file:../../../fonoster/mods/identity-client",
    "@fonoster/sdk": "file:../../../fonoster/mods/sdk",
    "@fonoster/voice": "file:../../../fonoster/mods/voice",
    "@grpc/grpc-js": "^1.10.6",
    "@prisma/client": "^6.0.0",
    "@qcobro/common": "*",
    "@trpc/server": "^11.0.0",
    "cors": "^2.8.5",
    "express": "^5.0.0",
    "twilio": "^5.13.1",
    "yaml": "^2.9.0",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "prisma": "^6.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.9.0"
  }
}
