{
  "name": "@qcobro/apiserver",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./src/trpc/index.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "prisma generate && tsc -b --force",
    "clean": "rm -rf dist *.tsbuildinfo",
    "start": "node dist/index.js",
    "start:dev": "tsx watch src/index.ts",
    "typecheck": "tsc --noEmit",
    "test": "mocha",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:migrate:deploy": "prisma migrate deploy",
    "db:push": "prisma db push",
    "db:studio": "prisma studio",
    "db:seed": "node prisma/seed-direct.mjs",
    "db:reset": "prisma migrate reset"
  },
  "dependencies": {
    "@fonoster/sdk": "^0.18.2",
    "@prisma/adapter-better-sqlite3": "^7.0.0",
    "@prisma/client": "^7.0.0",
    "@qcobro/agents": "*",
    "@qcobro/common": "*",
    "@trpc/server": "^11.0.0",
    "bcryptjs": "^3.0.0",
    "better-sqlite3": "^11.0.0",
    "cors": "^2.8.5",
    "express": "^5.0.0",
    "jose": "^6.0.0",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/better-sqlite3": "^7.6.0",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "chai": "^6.0.0",
    "mocha": "^11.0.0",
    "prisma": "^7.0.0",
    "sinon": "^21.0.0",
    "sinon-chai": "^4.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.9.0"
  }
}
