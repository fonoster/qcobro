{
  "name": "@qcobro/apiserver",
  "version": "1.20.3",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./src/trpc/index.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "node scripts/prisma.mjs generate && tsc -b --force",
    "clean": "rm -rf dist *.tsbuildinfo",
    "start": "node dist/index.js",
    "start:dev": "tsx watch src/index.ts",
    "test": "node --import tsx --test \"src/**/*.test.ts\"",
    "typecheck": "tsc --noEmit",
    "engine:sim": "tsx scripts/simulate-engine-tick.ts",
    "apikey:create": "tsx scripts/create-api-key.ts",
    "db:generate": "node scripts/prisma.mjs generate",
    "db:migrate": "node scripts/prisma.mjs migrate dev",
    "db:migrate:deploy": "node scripts/prisma.mjs migrate deploy",
    "db:reset": "node scripts/prisma.mjs migrate reset --force --skip-seed",
    "db:studio": "node scripts/prisma.mjs studio",
    "db:seed": "tsx scripts/seed.ts",
    "email:smoke": "tsx scripts/smoke-test-email.ts",
    "email:smoke-reply": "tsx scripts/smoke-test-email-reply.ts",
    "billing:sim": "tsx scripts/simulate-billing.ts"
  },
  "dependencies": {
    "@fonoster/identity-client": "0.22.0",
    "@fonoster/logger": "0.22.0",
    "@fonoster/sdk": "0.22.2",
    "@fonoster/voice": "0.22.0",
    "@grpc/grpc-js": "^1.10.6",
    "@prisma/client": "^6.0.0",
    "@qcobro/common": "^1.20.2",
    "@trpc/server": "^11.0.0",
    "cors": "^2.8.5",
    "express": "^5.0.0",
    "prisma-field-encryption": "^1.6.0",
    "stripe": "^22.3.1",
    "twilio": "^5.13.1",
    "yaml": "^2.9.0",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "prisma": "^6.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.9.0"
  }
}
