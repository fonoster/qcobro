generator client {
  provider        = "prisma-client-js"
  output          = "../src/generated/prisma"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  nombre       String
  rol          String   @default("AGENTE")
  passwordHash String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@map("users")
}

model Cartera {
  id               String    @id @default(uuid())
  nombre           String
  clienteId        String
  cuentas          Int       @default(0)
  montoTotal       Float     @default(0)
  montoRecuperado  Float     @default(0)
  estado           String    @default("ACTIVA")
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  campanas         Campana[]

  @@map("carteras")
}

model Campana {
  id        String    @id @default(uuid())
  nombre    String
  carteraId String
  estado    String    @default("PROGRAMADA")
  cuentas   Int       @default(0)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  cartera   Cartera   @relation(fields: [carteraId], references: [id])
  gestiones Gestion[]

  @@map("campanas")
}

model Gestion {
  id        String   @id @default(uuid())
  campanaId String
  cuentaId  String
  agenteId  String?
  resultado String   @default("PENDIENTE")
  notas     String?
  createdAt DateTime @default(now())
  campana   Campana  @relation(fields: [campanaId], references: [id])
  promesas  Promesa[]

  @@map("gestiones")
}

model Promesa {
  id           String   @id @default(uuid())
  gestionId    String
  cuentaId     String
  monto        Float
  fechaPromesa DateTime
  estado       String   @default("PENDIENTE")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  gestion      Gestion  @relation(fields: [gestionId], references: [id])

  @@map("promesas")
}

model Agente {
  id         String   @id @default(uuid())
  nombre     String
  estrategia String   @default("MODERADO")
  estado     String   @default("ACTIVO")
  llamadas   Int      @default(0)
  promesas   Int      @default(0)
  recuperado Float    @default(0)
  tasaExito  Float    @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@map("agentes")
}
