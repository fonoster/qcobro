generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model HealthCheck {
  id        String   @id @default(uuid())
  note      String   @default("ok")
  createdAt DateTime @default(now())
}

enum Currency {
  USD
  DOP
}

// Per-workspace settings owned by the app (keyed by the Identity workspaceRef);
// the Identity service is never modified. Holds the workspace's currency + timezone.
model WorkspaceSettings {
  workspaceRef String   @id
  currency     Currency @default(USD)
  timezone     String   @default("America/Costa_Rica")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@map("workspace_settings")
}

// Per-user settings owned by the app (keyed by the Identity userRef); the Identity
// service is never modified. Holds the user's console language preference.
model UserSettings {
  userRef   String   @id
  language  String   @default("es")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("user_settings")
}

enum AgentType {
  SMS
  VOICE_PRERECORDED
  VOICE_AI
  EMAIL
  WHATSAPP
}

enum CampaignStatus {
  PAUSED
  ACTIVE
  COMPLETED
  ARCHIVED
}

enum TriggerType {
  MAX_ATTEMPTS_PER_DAY
  DNC_CHECK
  WRONG_NUMBER
  OPT_OUT
  PAYMENT_PROMISE
  INTENT_MET
  CALLBACK_REQUESTED
}

enum ContactOutcome {
  DELIVERED
  NOT_DELIVERED
  NO_ANSWER
  PAYMENT_PROMISE
  PARTIAL_PAYMENT_AGREED
  NEW_TERMS
  CALLBACK_REQUESTED
  DISPUTE_RAISED
  INFORMATION_REQUEST
  RESOLVED
  PAID
  WRONG_NUMBER
  OPT_OUT
  REFUSED
  OTHER
}

enum IntentStatus {
  INTENT_MET
  WRONG_NUMBER
  OPT_OUT
}

enum PaymentPromiseStatus {
  PENDING
  MET
  EXPIRED
  CANCELLED
}

model Portfolio {
  id                      String              @id @default(uuid())
  workspaceRef            String
  name                    String
  clientId                String
  accountCount            Int                 @default(0)
  totalOutstandingBalance Float               @default(0)
  recoveredAmount         Float               @default(0)
  lastSyncedAt            DateTime?
  archivedAt              DateTime?
  createdAt               DateTime            @default(now())
  updatedAt               DateTime            @updatedAt
  accounts                PortfolioAccount[]
  campaignLinks           CampaignPortfolio[]

  @@index([workspaceRef, archivedAt])
  @@map("portfolios")
}

model PortfolioAccount {
  id                 String                 @id @default(uuid())
  portfolioId        String
  externalId         String
  fullName           String
  phone              String?
  email              String?
  preferredLanguage  String?
  bestTimeToCall     String?
  customerSegment    String?
  principalAmount    Float                  @default(0)
  termsAmount        Float                  @default(0)
  termsFrequency     String?
  termsLength        Int                    @default(0)
  outstandingBalance Float                  @default(0)
  daysPastDue        Int                    @default(0)
  missedInstallments Int                    @default(0)
  lastPaymentDate    DateTime?
  lastPaymentAmount  Float?
  negotiationOptions String?
  archivedAt         DateTime?
  lastContactedAt    DateTime?
  suppressUntil      DateTime?
  intentStatus       IntentStatus?
  totalAttempts      Int                    @default(0)
  createdAt          DateTime               @default(now())
  updatedAt          DateTime               @updatedAt
  portfolio          Portfolio              @relation(fields: [portfolioId], references: [id], onDelete: Cascade)
  campaignStates     CampaignAccountState[]
  contactLogs        AccountContactLog[]
  paymentPromises    PaymentPromise[]

  @@unique([portfolioId, externalId])
  @@index([portfolioId, archivedAt])
  @@map("portfolio_accounts")
}

model AgentTemplate {
  id                     String                  @id @default(uuid())
  workspaceRef           String
  name                   String
  type                   AgentType
  archivedAt             DateTime?
  createdAt              DateTime                @default(now())
  updatedAt              DateTime                @updatedAt
  voiceAiConfig          VoiceAiConfig?
  voicePrerecordedConfig VoicePrerecordedConfig?
  smsConfig              SmsConfig?
  emailConfig            EmailConfig?
  whatsAppConfig         WhatsAppConfig?
  campaigns              Campaign[]

  @@index([workspaceRef, archivedAt])
  @@map("agent_templates")
}

model VoiceAiConfig {
  templateId      String        @id
  fonosterAppName String
  fonosterAppRef  String?
  voice           String
  systemPrompt    String
  firstMessage    String?
  language        String
  template        AgentTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)

  @@map("voice_ai_configs")
}

model VoicePrerecordedConfig {
  templateId      String        @id
  fonosterAppName String
  fonosterAppRef  String?
  voice           String
  script          String
  language        String
  template        AgentTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)

  @@map("voice_prerecorded_configs")
}

model SmsConfig {
  templateId  String        @id
  messageBody String
  senderId    String?
  template    AgentTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)

  @@map("sms_configs")
}

model EmailConfig {
  templateId   String        @id
  subject      String
  messageBody  String
  fromName     String
  fromEmail    String
  // Autopilot decision brain: governs reply/ignore/resolve/escalate on each inbound reply.
  systemPrompt String        @default("")
  // Per-agent cap on autopilot replies per collection attempt; null → deployment default.
  maxReplies   Int?
  template     AgentTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)

  @@map("email_configs")
}

model WhatsAppConfig {
  templateId     String        @id
  // The Meta-side template id the operator enters; QCobro resolves + previews from the WABA.
  metaTemplateId String        @default("")
  templateName   String
  messageBody    String
  // Smart-agent decision brain for replies after the customer responds (mirrors EmailConfig).
  systemPrompt   String        @default("")
  // Per-agent cap on automated replies per gestión; null → deployment default.
  maxReplies     Int?
  template       AgentTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)

  @@map("whatsapp_configs")
}

model Campaign {
  id                     String                 @id @default(uuid())
  workspaceRef           String
  name                   String
  agentTemplateId        String
  status                 CampaignStatus         @default(ACTIVE)
  startDate              DateTime
  endDate                DateTime?
  startTime              String
  endTime                String
  daysOfWeek             Int[]
  maxAttemptsPerAccount  Int
  maxAttemptsPerDay      Int
  // WhatsApp campaigns send from one explicitly chosen sender number (not the random
  // global pool used by voice/SMS). Null for non-WhatsApp campaigns.
  whatsAppSenderNumberId String?
  createdAt              DateTime               @default(now())
  updatedAt              DateTime               @updatedAt
  agentTemplate          AgentTemplate          @relation(fields: [agentTemplateId], references: [id])
  whatsAppSenderNumber   WhatsAppSenderNumber?  @relation(fields: [whatsAppSenderNumberId], references: [id])
  portfolios             CampaignPortfolio[]
  triggers               CampaignTrigger[]
  accountStates          CampaignAccountState[]
  contactLogs            AccountContactLog[]

  @@index([workspaceRef])
  @@map("campaigns")
}

// Per-workspace WhatsApp Business Account (WABA) — QCobro's first tenant-provided secret.
// At most one per workspace. The access token is encrypted at rest via prisma-field-encryption
// (the Fonoster/Routr "cloak" pattern); it is never returned to clients or logged in plaintext.
model WhatsAppIntegration {
  id              String                 @id @default(uuid())
  workspaceRef    String                 @unique
  wabaId          String
  /// @encrypted
  accessToken     String
  verifyToken     String
  // Meta template-send language for this workspace's WhatsApp (e.g. es_DO); the single
  // source for the WhatsApp send language. Lives here so all WhatsApp config is together.
  defaultLanguage String
  // Cached result of the last "is this WABA/token still reachable" check against Meta's
  // Graph API, so the console's connected badge doesn't call Meta on every render/poll
  // (see getWhatsAppIntegration.ts for the TTL). Null until the first check runs; also
  // reset to null on upsert so a rotated token is re-validated instead of trusting a
  // cached result for credentials that no longer exist.
  lastCheckedAt   DateTime?
  lastCheckedOk   Boolean?
  createdAt       DateTime               @default(now())
  updatedAt       DateTime               @updatedAt
  senderNumbers   WhatsAppSenderNumber[]

  @@map("whatsapp_integrations")
}

// A WhatsApp sender number under a workspace's integration. phoneNumberId is globally
// unique so inbound webhook events resolve to exactly one workspace + sender. `capabilities`
// is a flag set ({ messaging, calling }) — messaging now, calling reserved for WhatsApp Voice.
model WhatsAppSenderNumber {
  id            String              @id @default(uuid())
  workspaceRef  String
  phoneNumberId String              @unique
  displayNumber String
  label         String
  qualityRating String?
  capabilities  Json
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt
  integration   WhatsAppIntegration @relation(fields: [workspaceRef], references: [workspaceRef], onDelete: Cascade)
  campaigns     Campaign[]

  @@index([workspaceRef])
  @@map("whatsapp_sender_numbers")
}

model CampaignPortfolio {
  campaignId  String
  portfolioId String
  campaign    Campaign  @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  portfolio   Portfolio @relation(fields: [portfolioId], references: [id], onDelete: Cascade)

  @@id([campaignId, portfolioId])
  @@index([portfolioId])
  @@map("campaign_portfolios")
}

model CampaignTrigger {
  id         String      @id @default(uuid())
  campaignId String
  type       TriggerType
  config     Json
  campaign   Campaign    @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  @@index([campaignId])
  @@map("campaign_triggers")
}

model CampaignAccountState {
  campaignId         String
  portfolioAccountId String
  attemptCount       Int              @default(0)
  attemptsToday      Int              @default(0)
  lastAttemptAt      DateTime?
  suppressUntil      DateTime?
  campaign           Campaign         @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  portfolioAccount   PortfolioAccount @relation(fields: [portfolioAccountId], references: [id], onDelete: Cascade)

  @@id([campaignId, portfolioAccountId])
  @@index([portfolioAccountId])
  @@map("campaign_account_states")
}

model AccountContactLog {
  id                 String           @id @default(uuid())
  portfolioAccountId String
  campaignId         String?
  agentType          AgentType
  contactedAt        DateTime
  durationSeconds    Int?
  outcome            ContactOutcome
  notes              String?
  debtAmountSnapshot Float?
  aiSummary          String?
  aiSentiment        String?
  aiDebtReason       String?
  aiResult           String?
  aiNextStep         String?
  intentMetadata     Json?
  channelData        Json?
  correctedEntryId   String?
  // Agent template used for the attempt (campaign dispatch or ad-hoc follow-up).
  agentTemplateId    String?
  // Set when this gestión is an ad-hoc follow-up on a specific PaymentPromise.
  paymentPromiseId   String?
  // Provider call ref (voice) / message sid (sms) for the dispatch-time attempt.
  // The engine writes one gestión per attempt keyed by this; the async outcome
  // callback correlates on it to enrich the same row (no duplicate gestiones).
  // Unique so re-delivered webhooks upsert rather than insert (nulls allowed for
  // legacy/manual rows without a ref).
  providerRef        String?          @unique
  createdAt          DateTime         @default(now())
  portfolioAccount   PortfolioAccount @relation(fields: [portfolioAccountId], references: [id], onDelete: Cascade)
  campaign           Campaign?        @relation(fields: [campaignId], references: [id], onDelete: SetNull)
  paymentPromises    PaymentPromise[]

  @@index([portfolioAccountId, createdAt])
  @@map("account_contact_logs")
}

model PaymentPromise {
  id                 String               @id @default(uuid())
  contactLogId       String
  portfolioAccountId String
  amount             Float?
  dueDate            DateTime
  status             PaymentPromiseStatus @default(PENDING)
  notes              String?
  createdAt          DateTime             @default(now())
  updatedAt          DateTime             @updatedAt
  contactLog         AccountContactLog    @relation(fields: [contactLogId], references: [id], onDelete: Cascade)
  portfolioAccount   PortfolioAccount     @relation(fields: [portfolioAccountId], references: [id], onDelete: Cascade)

  // One promise per gestión: a re-delivered outcome callback cannot duplicate it.
  @@unique([contactLogId])
  @@index([portfolioAccountId, dueDate])
  @@map("payment_promises")
}

enum EngineEventKind {
  TICK_STARTED
  TICK_COMPLETED
  CAMPAIGN_EVALUATED
  ACCOUNT_DECIDED
  ATTEMPT_RESERVED
  DISPATCH_REQUESTED
  DISPATCH_SUCCEEDED
  DISPATCH_FAILED
  PROVIDER_EVENT
}

// Engine flight recorder (engine-events capability). Append-only telemetry, not a
// system of record: gestiones stay authoritative. Typed columns are the correlation
// spine used for filtering; `payload` holds the full EngineEvent JSON (the shape the
// evaluator in @qcobro/common consumes). Pruned by `engine.eventsRetentionDays`.
// Intentionally relation-free so writes never contend with dispatch-path rows and
// events survive campaign/account deletion.
model EngineEvent {
  id                 String          @id
  tickId             String?
  seq                Int?
  kind               EngineEventKind
  at                 DateTime
  workspaceRef       String?
  campaignId         String?
  portfolioAccountId String?
  providerRef        String?
  channel            String?
  payload            Json
  createdAt          DateTime        @default(now())

  @@index([tickId])
  @@index([campaignId, at])
  @@index([providerRef])
  @@index([at])
  @@map("engine_events")
}

// ---------------------------------------------------------------------------
// Workspace billing (workspace-billing capability)
// ---------------------------------------------------------------------------

// The payer: owns the Stripe customer (one card), the subscription, and the
// dunning state. Free-standing — created lazily from the workspace owner on the
// first paid plan, but not identity-keyed, so payership can move without
// migration (future org billing). Workspaces point at it via WorkspaceBilling.
model BillingAccount {
  id                   String             @id @default(uuid())
  // The owner userRef this account was created from (provenance, not a key).
  createdFromUserRef   String
  stripeCustomerId     String             @unique
  stripeSubscriptionId String?            @unique
  // "charge_automatically" (card) or "send_invoice" (enterprise invoicing).
  collectionMethod     String             @default("charge_automatically")
  // Payment-failure dunning: distinct from credit exhaustion. While true, all
  // this account's workspaces stop dispatching with a payment-failed status.
  paymentFailed        Boolean            @default(false)
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt
  workspaces           WorkspaceBilling[]

  @@map("billing_accounts")
}

// The cost center: one row per workspace on a plan. Plan/rate resolution reads
// this row; balances derive from LedgerEntry, never stored here.
model WorkspaceBilling {
  workspaceRef             String         @id
  billingAccountId         String
  // Key into the qcobro.json billing.plans catalog (rates resolved at write time).
  planKey                  String
  // Enterprise per-meter overrides: a Partial of the shared rates schema.
  rateOverrides            Json?
  stripeSubscriptionItemId String?        @unique
  // Current allowance cycle (opened by the invoice.paid webhook).
  cycleStart               DateTime?
  cycleEnd                 DateTime?
  createdAt                DateTime       @default(now())
  updatedAt                DateTime       @updatedAt
  billingAccount           BillingAccount @relation(fields: [billingAccountId], references: [id])

  @@index([billingAccountId])
  @@map("workspace_billing")
}

enum BillingMeter {
  SMS
  EMAIL
  WHATSAPP_MESSAGE
  VOICE_PRERECORDED
  VOICE_AI
  WHATSAPP_VOICE_PRERECORDED
  WHATSAPP_VOICE_AI
}

enum LedgerEntryKind {
  GRANT
  USAGE_DEBIT
  VOID
  ADJUSTMENT
}

// One priced billable event, written in the SAME transaction as the dispatch's
// gestión — never via the (lossy) engine event sink, and never pruned. Priced at
// write time: unit price (and voice increments) are frozen on the row so later
// plan/rate changes cannot reprice history. Voice rows start as the dispatch-time
// estimate and are corrected to the actual answered duration at settlement
// (settledAt marks it; the ledger delta lands as an ADJUSTMENT entry).
// Intentionally relation-free (like EngineEvent): billing history survives
// campaign/account deletion.
model UsageRecord {
  id                 String       @id @default(uuid())
  workspaceRef       String
  meter              BillingMeter
  // Message meters: messages (1). Voice meters: increment-billed seconds.
  quantity           Int
  // Message meters: micro-units per message. Voice meters: micro-units per minute.
  unitPriceMicro     BigInt
  amountMicro        BigInt
  // Voice only: the increment notation ("15/15") frozen at dispatch, so
  // settlement re-prices with the dispatch-time rate even if the plan changed.
  increments         String?
  // Voice only: set when the completion webhook settled the actual duration.
  settledAt          DateTime?
  campaignId         String?
  portfolioAccountId String?
  providerRef        String?      @unique
  at                 DateTime
  createdAt          DateTime     @default(now())

  @@index([workspaceRef, at])
  @@map("usage_records")
}

// The signed ledger a workspace balance derives from. Sign conventions:
// GRANT (+) opens a cycle, USAGE_DEBIT (−) prices a dispatch, VOID (−) expires
// the unused remainder at cycle close (no rollover), ADJUSTMENT (±) settles a
// voice estimate to its actual amount. Cycle turnover is idempotent via the
// (workspaceRef, stripeInvoiceId, kind) unique — a replayed invoice.paid
// webhook cannot double-grant or double-void. Relation-free like UsageRecord.
model LedgerEntry {
  id              String          @id @default(uuid())
  workspaceRef    String
  kind            LedgerEntryKind
  amountMicro     BigInt
  at              DateTime
  usageRecordId   String?
  stripeInvoiceId String?
  createdAt       DateTime        @default(now())

  @@unique([workspaceRef, stripeInvoiceId, kind])
  @@unique([usageRecordId, kind])
  @@index([workspaceRef, at])
  @@map("ledger_entries")
}
