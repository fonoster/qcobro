{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ES2022",
    "lib": ["ES2022"],
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "strict": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "composite": true,
    "incremental": true,
    "skipLibCheck": true
  },
  "references": [
    { "path": "./mods/common" },
    { "path": "./mods/apiserver" },
    { "path": "./mods/sdk" },
    { "path": "./mods/mcp" }
  ]
}
